{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=TradingCsvProcessor;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "FileStorage": {
    "Path": "uploads"
  },
  "Processing": {
    "ChunkSize": 5000,
    "DegreeOfParallelism": 4,
    "ChannelCapacity": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
